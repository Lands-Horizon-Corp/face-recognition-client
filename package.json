{
  "name": "face-recognition-client",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "start": "bun run .output/server/index.mjs",
    "dev": "vite --port 3000 --host",
    "test": "vitest run .",
    "testw": "vitest",
    "lint": "eslint .",
    "lf": "eslint .",
    "preview": "vite preview --port $PORT --host",
    "pwa-test": "bun run build && bun run preview",
    "fc": "prettier . -c",
    "fcf": "prettier -c",
    "fw": "prettier . -w",
    "fwf": "prettier -w",
    "el": "eslint .",
    "elf": "eslint . --fix",
    "fmt": "eslint . --fix && prettier . -w",
    "build": "tsc -b && bun --bun vite build",
    "vc": "eslint . && prettier . -c && vitest run && tsc -b --verbose && vite build",
    "dick": "bun run fmt && bun run vc",
    "gen-mod": "bunx plop module-gen",
    "unused": "knip"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.72.1",
    "react-webcam": "^7.2.0",
    "shadcn": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}